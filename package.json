{
  "name": "Charmventory",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxi build --preset=cloudflare_pages",
    "dev": "nuxt dev --host",
    "generate": "nuxt generate",
    "preview": "npm run build && wrangler pages dev dist/",
    "postinstall": "nuxt prepare",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "scrape": "npx tsx scripts/run-scraper.ts",
    "scrape:all": "npx tsx scripts/run-scraper.ts all"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@aws-sdk/s3-request-presigner": "^3.1019.0",
    "@neondatabase/auth": "^0.1.0-beta.21",
    "@neondatabase/neon-js": "^0.2.0-beta.1",
    "@neondatabase/postgrest-js": "^0.1.0-alpha.2",
    "@neondatabase/serverless": "^1.0.2",
    "drizzle-orm": "^0.45.2",
    "nuxt": "^4.4.2",
    "page-flip": "^2.0.7",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^3.11.174",
    "puppeteer-core": "^24.40.0",
    "tesseract.js": "^7.0.0",
    "vue": "^3.5.30",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@nuxtjs/google-fonts": "^3.2.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@vite-pwa/nuxt": "^1.1.1",
    "drizzle-kit": "^0.31.10"
  }
}
